// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Access {
  id          Int       @id @default(autoincrement())
  userId      String    @unique  // Telegram user_id (bigint!)
  username    String?
  accessUntil Int    // Unix timestamp
  createdAt   DateTime  @default(now())
  
  @@index([accessUntil])  // Для быстрого поиска expired
  @@map("access")
}